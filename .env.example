# ============================================
# SBOUP Environment Configuration
# Copy this file to .env and fill in values
# ============================================

# --- General ---
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# --- MongoDB ---
# The team uses a SHARED MongoDB Atlas cluster. Paste the connection string the
# team lead shared with you privately (group chat / password manager) — do this
# ONCE; you never edit it again. The real value lives only in your gitignored
# .env, never in git.
#   Format: mongodb+srv://<user>:<password>@sboup-cluster.xxxxx.mongodb.net/sboup?retryWrites=true&w=majority
# Leave the local fallback below if you'd rather run the Dockerized Mongo instead.
MONGODB_URI=mongodb://localhost:27017/sboup_dev

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- JWT Authentication ---
# The default below is a working DEV secret so the server boots immediately
# after `cp .env.example .env`. Replace it for any non-dev deployment.
JWT_SECRET=sboup-dev-jwt-secret-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# --- Google OAuth 2.0 ---
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# --- Email (SendGrid) ---
SENDGRID_API_KEY=your-sendgrid-api-key
EMAIL_FROM=noreply@skillbridge.ug

# --- AWS S3 / Azure Blob Storage ---
STORAGE_PROVIDER=s3
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=sboup-uploads
AWS_REGION=af-south-1

# --- AI Microservices URLs ---
MATCHING_SERVICE_URL=http://localhost:5001
FRAUD_DETECTION_SERVICE_URL=http://localhost:5002
CV_GENERATION_SERVICE_URL=http://localhost:5003
LEARNING_SERVICE_URL=http://localhost:5004
CHATBOT_SERVICE_URL=http://localhost:5005

# --- YouTube Data API ---
YOUTUBE_API_KEY=your-youtube-api-key

# --- Rate Limiting ---
# 15-minute window, 1000 requests per IP. Lower for hardened prod, but
# the previous default (100) was unusably tight for a normal mobile
# session: a single dashboard mount + a few minutes of navigation +
# the 30s unread-count poller easily exceeds 100/15min.
# Cheap pollers like /unread-count are exempted in middleware/rateLimiter.js.
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=1000

# --- File Upload ---
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=pdf,doc,docx,png,jpg,jpeg

# --- Fraud Detection Thresholds ---
FRAUD_LOW_THRESHOLD=30
FRAUD_HIGH_THRESHOLD=70

# --- Account Security ---
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30

# --- Chatbot Service (Kazi) ---
# A shared Groq key is baked into docker-compose.yml as a fallback so the
# chatbot works for all team members without any setup. You can override it
# here with your own key if you prefer (your key takes priority).
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile
