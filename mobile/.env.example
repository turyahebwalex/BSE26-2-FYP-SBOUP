# Copy this file to .env (in mobile/) after cloning:
#   cp mobile/.env.example mobile/.env
#
# EXPO_PUBLIC_API_URL MUST be a URL your phone can reach:
#   - Expo Go on a physical phone CANNOT use `localhost` or `127.0.0.1`
#     because those resolve to the phone itself.
#   - Use your computer's LAN IP (same WiFi as phone), e.g.
#       http://192.168.1.42:5000/api
#     Find yours with:
#       ip -4 addr show | awk '/inet / {print $2}'   # Linux
#       ipconfig getifaddr en0                        # macOS
#   - If LAN doesn't work (different WiFi, university wifi with client
#     isolation, strict firewall), run Expo in tunnel mode:
#       npm run start:tunnel
#     ...and set this to your computer's LAN IP anyway — the tunnel
#     proxies the JS bundle, but your app still calls the API at this URL.
EXPO_PUBLIC_API_URL=http://localhost:5000/api
