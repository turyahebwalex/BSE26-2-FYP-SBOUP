# By default mobile/src/services/api.js auto-detects the backend host from
# Metro's dev-server address — any collaborator on the same Wi-Fi as their
# phone gets the right IP automatically. Leave EXPO_PUBLIC_API_URL UNSET
# (commented out) to use auto-detect.
#
# Override only when:
#   * The phone is NOT on the same Wi-Fi as the laptop (cellular, different
#     network, university Wi-Fi with client isolation), AND you've exposed
#     the backend through a tunnel (ngrok, serveo, localtunnel, etc):
#       EXPO_PUBLIC_API_URL=https://your-tunnel-url.example.com/api
#   * You want the app to talk to a deployed backend instead of localhost:
#       EXPO_PUBLIC_API_URL=https://api.skillbridge.ug/api
#
# EXPO_PUBLIC_API_URL=
