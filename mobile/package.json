{
  "name": "sboup-mobile",
  "version": "1.0.0",
  "main": "expo/AppEntry",
  "scripts": {
    "start": "expo start",
    "start:lan": "expo start --lan --clear",
    "start:wifi": "expo start --lan --clear --go",
    "start:usb": "adb reverse tcp:8081 tcp:8081 && adb reverse tcp:5000 tcp:5000 && EXPO_PUBLIC_API_URL=http://127.0.0.1:5000/api expo start --localhost --go",
    "start:usb:clean": "adb reverse tcp:8081 tcp:8081 && adb reverse tcp:5000 tcp:5000 && EXPO_PUBLIC_API_URL=http://127.0.0.1:5000/api expo start --localhost --clear --go",
    "start:tunnel": "expo start --tunnel --clear",
    "adb:reverse": "adb reverse tcp:8081 tcp:8081 && adb reverse tcp:5000 tcp:5000",
    "android": "expo start --android",
    "ios": "expo start --ios"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.1.0",
    "@react-navigation/bottom-tabs": "^7.0.0",
    "@react-navigation/native": "^7.0.0",
    "@react-navigation/native-stack": "^7.0.0",
    "axios": "^1.7.0",
    "expo": "~54.0.34",
    "expo-asset": "~12.0.13",
    "expo-font": "~14.0.11",
    "expo-linking": "~8.0.12",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-vector-icons": "^10.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "babel-preset-expo": "~54.0.0"
  }
}
