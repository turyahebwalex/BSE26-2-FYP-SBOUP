MONGODB_URI=mongodb://localhost:27017/sboup_dev
MONGODB_DB_NAME=sboup_dev
INTERNAL_API_KEY=

HF_MODEL_CACHE_DIR=/app/model_cache
HF_SEMANTIC_MODEL=sentence-transformers/all-MiniLM-L6-v2
HF_SKILL_NER_MODEL=jjzha/escoxlmr_skill_extraction
HF_SUMMARY_MODEL=google/flan-t5-small
HF_SUMMARY_MAX_NEW_TOKENS=120

# local | s3 | azure
# Use `local` for development (no S3 credentials required) — files written
# to LOCAL_STORAGE_DIR and served via /static/cvs/{cvId}.pdf.
STORAGE_BACKEND=local
LOCAL_STORAGE_DIR=/app/storage
# IMPORTANT: when the mobile client (Expo Go) downloads the CV, the URL must
# resolve from the *phone*. `localhost` works for browser/curl on the dev
# machine but NOT from a phone on the LAN. Use the dev machine's LAN IP for
# phone testing, e.g. http://10.85.118.126:5003
PUBLIC_BASE_URL=http://localhost:5003

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=sboup-cv-storage

CV_PRESIGNED_URL_EXPIRY_SECONDS=3600
RATE_LIMIT_PER_USER_PER_MINUTE=3

PORT=5003
LOG_LEVEL=INFO

# Set both to 1 once models are pre-downloaded into HF_MODEL_CACHE_DIR.
# In dev with no cache yet, leave them unset so first start can pull.
TRANSFORMERS_OFFLINE=0
HF_HUB_OFFLINE=0
