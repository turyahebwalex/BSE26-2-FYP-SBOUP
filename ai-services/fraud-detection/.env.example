PORT=5002
# Use the shared hosted MongoDB Atlas URI (get it from the team .env), e.g.:
#   MONGODB_URI=mongodb+srv://<user>:<pass>@sboup-cluster.ynhrutv.mongodb.net/sboup?retryWrites=true&w=majority&appName=sboup-cluster
# Local fallback:
MONGODB_URI=mongodb://localhost:27017/sboup_dev
FLASK_ENV=development
FRAUD_LOW_THRESHOLD=30
FRAUD_HIGH_THRESHOLD=70
# Optional Mongo handshake tuning (Atlas defaults: 8000 / 10000 ms)
# MONGO_SERVER_SELECTION_TIMEOUT_MS=8000
# MONGO_CONNECT_TIMEOUT_MS=10000
